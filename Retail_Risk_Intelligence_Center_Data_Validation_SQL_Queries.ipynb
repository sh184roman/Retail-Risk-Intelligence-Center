    "# Assessing survey response coverage by country\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT\n",
    "    c.CustomerCountry,\n",
    "    COUNT(*) AS SurveyResponses\n",
    "FROM CustomerSurvey cs\n",
    "INNER JOIN Customer c\n",
    "    ON cs.CustomerKey = c.CustomerKey\n",
    "GROUP BY c.CustomerCountry\n",
    "ORDER BY SurveyResponses DESC\n",
    "\"\"\"\n",
    "\n",
    "survey_country_df = pd.read_sql(query, conn)\n",
    "\n",
    "survey_country_df"
