    "# Validate Product relationships across all relevant fact tables\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT 'StoreSales' AS FactTable,\n",
    "       COUNT(*) AS MissingProducts\n",
    "FROM StoreSales s\n",
    "LEFT JOIN Product p\n",
