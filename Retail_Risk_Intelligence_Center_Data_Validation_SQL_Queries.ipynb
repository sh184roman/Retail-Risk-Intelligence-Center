   "source": [
    "# Identifying repeated Product-Store combinations\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT\n",
    "    ProductKey,\n",
    "    StoreKey,\n",
    "    COUNT(*) AS SnapshotCount\n",
    "FROM Inventory\n",
    "GROUP BY ProductKey, StoreKey\n",
    "HAVING COUNT(*) > 1\n",
    "ORDER BY SnapshotCount DESC\n",
    "\"\"\"\n",
    "\n",
    "snapshot_df = pd.read_sql(query, conn)\n",
    "\n",
    "snapshot_df.head(200)"
   ]
  },
