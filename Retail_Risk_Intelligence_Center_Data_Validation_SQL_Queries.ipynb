    "# Verifying that all Contoso tables are available in the database\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT TABLE_NAME\n",
    "FROM INFORMATION_SCHEMA.TABLES\n",
    "WHERE TABLE_TYPE = 'BASE TABLE'\n",
    "ORDER BY TABLE_NAME\n",
    "\"\"\"\n",
    "\n",
    "# Execute query and display results\n",
    "tables_df = pd.read_sql(query, conn)\n",
    "\n",
    "# Display table list\n",
    "tables_df"
   ]
