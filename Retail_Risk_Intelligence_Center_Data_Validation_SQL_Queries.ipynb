   "source": [
    "# Calculating product coverage within sales transactions\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT\n",
    "    COUNT(DISTINCT s.ProductKey) * 100.0 /\n",
    "    COUNT(DISTINCT p.ProductKey) AS ProductCoveragePercentage\n",
    "FROM Product p\n",
    "LEFT JOIN StoreSales s\n",
    "    ON p.ProductKey = s.ProductKey\n",
    "\"\"\"\n",
    "\n",
    "product_coverage_df = pd.read_sql(query, conn)\n",
    "\n",
    "product_coverage_df"
   ]
