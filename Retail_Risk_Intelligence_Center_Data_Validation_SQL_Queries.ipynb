    "# Assessing inventory status distribution\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT\n",
    "    StockStatus,\n",
    "    COUNT(*) AS RecordCount\n",
    "FROM Inventory\n",
    "GROUP BY StockStatus\n",
    "ORDER BY RecordCount DESC\n",
    "\"\"\"\n",
    "\n",
    "stock_status_df = pd.read_sql(query, conn)\n",
    "\n",
    "stock_status_df"
   ]
  },
