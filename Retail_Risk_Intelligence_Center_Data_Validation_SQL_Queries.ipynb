    "# Validate Date relationships across all fact tables\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT 'StoreSales' AS FactTable,\n",
    "       COUNT(*) AS MissingDates\n",
    "FROM StoreSales s\n",
    "LEFT JOIN Date d\n",
    "       ON s.DateKey = d.DateKey\n",
    "WHERE d.DateKey IS NULL\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT 'OnlineSales',\n",
    "       COUNT(*)\n",
    "FROM OnlineSales o\n",
    "LEFT JOIN Date d\n",
    "       ON o.DateKey = d.DateKey\n",
    "WHERE d.DateKey IS NULL\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT 'Inventory',\n",
    "       COUNT(*)\n",
    "FROM Inventory i\n",
    "LEFT JOIN Date d\n",
    "       ON i.DateKey = d.DateKey\n",
    "WHERE d.DateKey IS NULL\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT 'SalesQuota',\n",
    "       COUNT(*)\n",
    "FROM SalesQuota q\n",
    "LEFT JOIN Date d\n",
    "       ON q.DateKey = d.DateKey\n",
    "WHERE d.DateKey IS NULL\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT 'CustomerSurvey',\n",
    "       COUNT(*)\n",
    "FROM CustomerSurvey cs\n",
    "LEFT JOIN Date d\n",
    "       ON cs.SurveyDateKey = d.DateKey\n",
    "WHERE d.DateKey IS NULL\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT 'OrderFulfillment',\n",
