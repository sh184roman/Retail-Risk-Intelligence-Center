   "source": [
    "# Identifying products that never appeared in sales transactions\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT\n",
    "    p.ProductKey,\n",
    "    p.ProductName\n",
    "FROM Product p\n",
    "LEFT JOIN StoreSales s\n",
    "    ON p.ProductKey = s.ProductKey\n",
    "WHERE s.ProductKey IS NULL\n",
    "ORDER BY p.ProductKey\n",
    "\"\"\"\n",
    "\n",
    "inactive_products_df = pd.read_sql(query, conn)\n",
    "\n",
    "inactive_products_df"
   ]
