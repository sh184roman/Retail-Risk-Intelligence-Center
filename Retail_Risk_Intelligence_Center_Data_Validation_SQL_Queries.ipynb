    "# Comparing date coverage across all major fact tables\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT\n",
    "    'StoreSales' AS FactTable,\n",
    "    MIN(DateKey) AS StartDate,\n",
    "    MAX(DateKey) AS EndDate\n",
    "FROM StoreSales\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT\n",
    "    'OnlineSales',\n",
    "    MIN(DateKey),\n",
    "    MAX(DateKey)\n",
    "FROM OnlineSales\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT\n",
    "    'Inventory',\n",
    "    MIN(DateKey),\n",
    "    MAX(DateKey)\n",
    "FROM Inventory\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT\n",
    "    'SalesQuota',\n",
    "    MIN(DateKey),\n",
    "    MAX(DateKey)\n",
    "FROM SalesQuota\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT\n",
    "    'CustomerSurvey',\n",
    "    MIN(SurveyDateKey),\n",
    "    MAX(SurveyDateKey)\n",
    "FROM CustomerSurvey\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT\n",
    "    'OrderFulfillment',\n",
    "    MIN(OrderDateKey),\n",
    "    MAX(OrderDateKey)\n",
    "FROM OrderFulfillment\n",
    "\"\"\"\n",
    "\n",
    "date_coverage_df = pd.read_sql(query, conn)\n",
    "\n",
    "date_coverage_df"
   ]
