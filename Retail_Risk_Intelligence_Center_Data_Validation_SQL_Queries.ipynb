    "# Validating record counts across key Contoso datasets\n",
    "query = \"\"\"\n",
    "SELECT 'StoreSales' AS TableName, COUNT(*) AS RecordCount FROM StoreSales\n",
    "UNION ALL\n",
    "SELECT 'SalesQuota', COUNT(*) FROM SalesQuota\n",
    "UNION ALL\n",
    "SELECT 'Returns', COUNT(*) FROM Returns\n",
    "UNION ALL\n",
    "SELECT 'OrderPayment', COUNT(*) FROM OrderPayment\n",
    "UNION ALL\n",
    "SELECT 'OrderFulfillment', COUNT(*) FROM OrderFulfillment\n",
    "UNION ALL\n",
    "SELECT 'OnlineSales', COUNT(*) FROM OnlineSales\n",
    "UNION ALL\n",
    "SELECT 'MarketingSpend', COUNT(*) FROM MarketingSpend\n",
    "UNION ALL\n",
    "SELECT 'Inventory', COUNT(*) FROM Inventory\n",
    "UNION ALL\n",
    "SELECT 'CustomerSurvey', COUNT(*) FROM CustomerSurvey\n",
    "UNION ALL\n",
    "SELECT 'ExchangeRate', COUNT(*) FROM ExchangeRate\n",
    "UNION ALL\n",
    "SELECT 'AcquisitionChannel', COUNT(*) FROM AcquisitionChannel\n",
    "UNION ALL\n",
    "SELECT 'Channel', COUNT(*) FROM Channel\n",
    "UNION ALL\n",
    "SELECT 'Currency', COUNT(*) FROM Currency\n",
    "UNION ALL\n",
    "SELECT 'Customer', COUNT(*) FROM Customer\n",
    "UNION ALL\n",
    "SELECT 'CustomerAcquisition', COUNT(*) FROM CustomerAcquisition\n",
    "UNION ALL\n",
    "SELECT 'Date', COUNT(*) FROM Date\n",
    "UNION ALL\n",
    "SELECT 'Employee', COUNT(*) FROM Employee\n",
    "UNION ALL\n",
    "SELECT 'PaymentMethod', COUNT(*) FROM PaymentMethod\n",
    "UNION ALL\n",
    "SELECT 'Product', COUNT(*) FROM Product\n",
    "UNION ALL\n",
    "SELECT 'Promotion', COUNT(*) FROM Promotion\n",
    "UNION ALL\n",
    "SELECT 'ReturnReason', COUNT(*) FROM ReturnReason\n",
    "UNION ALL\n",
    "SELECT 'Store', COUNT(*) FROM Store\n",
    "ORDER BY TableName\n",
    "\"\"\"\n",
    "\n",
    "record_counts_df = pd.read_sql(query, conn)\n",
    "\n",
    "record_counts_df"
   ]
