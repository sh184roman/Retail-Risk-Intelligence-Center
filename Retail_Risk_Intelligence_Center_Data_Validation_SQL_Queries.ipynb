    "# Checking for records with missing DateKeys\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT\n",
    "    'StoreSales' AS FactTable,\n",
    "    COUNT(*) AS MissingDates\n",
    "FROM StoreSales\n",
    "WHERE DateKey IS NULL\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT\n",
    "    'OnlineSales',\n",
    "    COUNT(*)\n",
    "FROM OnlineSales\n",
    "WHERE DateKey IS NULL\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT\n",
    "    'Inventory',\n",
    "    COUNT(*)\n",
    "FROM Inventory\n",
    "WHERE DateKey IS NULL\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT\n",
    "    'SalesQuota',\n",
    "    COUNT(*)\n",
    "FROM SalesQuota\n",
    "WHERE DateKey IS NULL\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT\n",
    "    'CustomerSurvey',\n",
    "    COUNT(*)\n",
    "FROM CustomerSurvey\n",
    "WHERE SurveyDateKey IS NULL\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT\n",
    "    'OrderFulfillment',\n",
    "    COUNT(*)\n",
    "FROM OrderFulfillment\n",
    "WHERE OrderDateKey IS NULL\n",
    "\"\"\"\n",
    "\n",
    "missing_dates_df = pd.read_sql(query, conn)\n",
