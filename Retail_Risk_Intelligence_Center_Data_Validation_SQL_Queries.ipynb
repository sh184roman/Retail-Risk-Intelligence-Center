   "source": [
    "# Identifying Currency Keys used within Store and Sales Tables\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT 'StoreSales' AS Source,\n",
    "       COUNT(DISTINCT CurrencyKey) AS CurrencyCount\n",
    "FROM StoreSales\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT 'OnlineSales',\n",
    "       COUNT(DISTINCT CurrencyKey)\n",
    "FROM OnlineSales\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT 'SalesQuota',\n",
    "       COUNT(DISTINCT CurrencyKey)\n",
    "FROM SalesQuota;\n",
    "\"\"\"\n",
    "\n",
    "currency_df = pd.read_sql(query, conn)\n",
    "\n",
    "currency_df"
   ]
