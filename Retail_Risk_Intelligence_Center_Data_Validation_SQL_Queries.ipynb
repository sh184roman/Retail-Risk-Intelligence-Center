    "    COUNT(DISTINCT DateKey) AS UniqueDates\n",
    "FROM StoreSales\n",
    "\"\"\"\n",
    "\n",
    "store_sales_date_df = pd.read_sql(query, conn)\n",
    "\n",
    "store_sales_date_df"
